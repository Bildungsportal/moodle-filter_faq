<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="filter/faq/db" VERSION="20260328" COMMENT="XMLDB file for Moodle filter/faq"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="filter_faq" COMMENT="Default comment for filter_faq, please edit me">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="path" TYPE="char" LENGTH="1333" NOTNULL="true" SEQUENCE="false" COMMENT="the path"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="20" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="filter_faq_pages" COMMENT="Keep track of faq pages and their versions to build a search index and table of contents">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="pathid" TYPE="int" LENGTH="20" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="lang" TYPE="char" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="version" TYPE="char" LENGTH="20" NOTNULL="false" SEQUENCE="false" COMMENT="version of the page"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="20" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="key_pathid" TYPE="foreign" FIELDS="pathid" REFTABLE="filter_faq" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_pathid_lang" UNIQUE="true" FIELDS="pathid, lang"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
